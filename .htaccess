<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /ELPROFE/

# Definir páginas de error personalizadas
ErrorDocument 403 /ELPROFE/error.php?code=403
ErrorDocument 404 /ELPROFE/error.php?code=404
ErrorDocument 500 /ELPROFE/error.php?code=500

# Evitar listar directorios por seguridad
Options -Indexes

# Si la solicitud es un archivo real (.css, .js) o carpeta real, no hacer nada y dejarlo pasar
RewriteCond %{REQUEST_FILENAME} -d [OR]
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# ==========================================
# RUTAS AMIGABLES EXPLÍCITAS (EXPLICIT ROUTES)
# ==========================================
# Core
RewriteRule ^login/?$ index.php [QSA,L]
RewriteRule ^dashboard/?$ dashboard.php [QSA,L]
RewriteRule ^logout/?$ logout.php [QSA,L]

# Modulos de Negocio
RewriteRule ^ventas/?$ pages/ventas.php [QSA,L]
RewriteRule ^mi_caja/?$ pages/mi_caja.php [QSA,L]
RewriteRule ^proformas/?$ pages/proformas.php [QSA,L]
RewriteRule ^inventario/?$ pages/inventario.php [QSA,L]
RewriteRule ^categorias/?$ pages/categorias.php [QSA,L]
RewriteRule ^compras/?$ pages/compras.php [QSA,L]
RewriteRule ^proveedores/?$ pages/proveedores.php [QSA,L]
RewriteRule ^caja/?$ pages/caja.php [QSA,L]
RewriteRule ^clientes/?$ pages/clientes.php [QSA,L]
RewriteRule ^configuracion/?$ pages/configuracion.php [QSA,L]
RewriteRule ^usuarios/?$ pages/usuarios.php [QSA,L]
RewriteRule ^bitacora/?$ pages/bitacora.php [QSA,L]
RewriteRule ^reportes/?$ pages/reportes.php [QSA,L]
RewriteRule ^acerca/?$ pages/acerca.php [QSA,L]
RewriteRule ^manual/?$ pages/manual.php [QSA,L]
RewriteRule ^perfil/?$ pages/perfil.php [QSA,L]
RewriteRule ^export_reportes/?$ pages/export_reportes.php [QSA,L]
RewriteRule ^export_caja/?$ pages/export_caja.php [QSA,L]

# Capturar cualquier otra ruta basura, ignorando archivos reales
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ error.php?code=404 [QSA,L]

</IfModule>
